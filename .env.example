# TripSync Backend — Environment Variables Template
# ==================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to source control.
# Keep .env in .gitignore.

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
# Options: development | production
# In production: startup fails if Firebase Admin credentials are missing

# ── Firebase Admin SDK ───────────────────────────────────────────────────────
# Option 1: Service account JSON file path (recommended for local dev)
FIREBASE_CREDENTIALS_PATH=firebase-adminsdk.json

# Option 2: Application Default Credentials (for GKE, Cloud Run)
# FIREBASE_PROJECT_ID=your-firebase-project-id

# ── CORS — Allowed Origins ───────────────────────────────────────────────────
# Comma-separated list of trusted frontend origins.
# Wildcard (*) is never accepted even if set here.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── SMTP — Email / OTP Delivery ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ── OTP Configuration ────────────────────────────────────────────────────────
OTP_TTL_SECONDS=300        # OTP valid for 5 minutes
OTP_MAX_ATTEMPTS=3         # Max failed verification attempts before invalidation
OTP_LENGTH=6               # OTP digit count

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_GLOBAL=60/minute
RATE_LIMIT_OTP=3/minute
RATE_LIMIT_AI=20/minute
RATE_LIMIT_UPLOAD=10/minute

# ── File Upload ──────────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=10485760  # 10 MB

# ── AI Services ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key
OPENAI_API_KEY=your-openai-api-key

# ── Vector Database ──────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Weather ──────────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your-openweather-api-key
